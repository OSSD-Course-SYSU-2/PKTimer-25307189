{
  "apiType": "stageMode",
  "buildOption": {
    "resOptions": {
      "copyCodeResource": {
        "enable": false
      }
    }
  },
  "buildOptionSet": [
    {
      "name": "release",
      "arkOptions": {
        "obfuscation": {
          "ruleOptions": {
            "enable": false,
            "files": [
              "./obfuscation-rules.txt"
            ]
          }
        }
      }
    },
  ],
  "targets": [
    {
      "name": "default",
      "runtimeOS": "HarmonyOS"
    },
    {
      "name": "ohosTest",
    },
    {
      "name": "phone",
      "runtimeOS": "HarmonyOS"
    },
    {
      "name": "tablet",
      "runtimeOS": "HarmonyOS"
    },
    {
      "name": "tv",
      "runtimeOS": "HarmonyOS"
    },
    {
      "name": "wearable",
      "runtimeOS": "HarmonyOS"
    },
    {
      "name": "car",
      "runtimeOS": "HarmonyOS"
    }
  ]
}